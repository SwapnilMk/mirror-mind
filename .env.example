```env
# =========================================================
# DATABASE
# =========================================================

# Primary database connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mirrormind"

# Direct database connection for Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/mirrormind"


# =========================================================
# NEXT AUTH
# =========================================================

# Generate using:
# openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key"

# Local development URL
NEXTAUTH_URL="http://localhost:3000"


# =========================================================
# AI CONFIGURATION
# =========================================================

# AI Provider API Key
AI_API_KEY="your-ai-api-key"

# AI Base URL
AI_BASE_URL="https://api.freemodel.dev"

# Default AI Model
AI_MODEL="claude-sonnet-4-6"

