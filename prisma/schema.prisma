generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  image             String?
  password          String?
  role              String             @default("user")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  profileMemory     ProfileMemory?
  decisions         Decision[]
  episodicMemories  EpisodicMemory[]
  messages          CompanionMessage[]
  reflectionReports ReflectionReport[]
  emotionAnalyses   EmotionAnalysis[]
}

model Decision {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  situation   String
  choice      String
  category    String    @default("other")
  outcome     String    @default("pending")
  confidence  Int       @default(70)
  emotion     String?   @default("Neutral")
  regretScore Int?      @default(0)
  stressLevel Int?      @default(5)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Float
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProfileMemory {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String?
  preferredName      String?
  age                Int?
  birthday           String?
  gender             String?
  country            String?
  language           String?
  profession         String?
  company            String?
  designation        String?
  routine            String?
  workStyle          String?
  goals              String[]
  ambitions          String[]
  traits             String[]
  riskStyle          String?
  fears              String[]
  motivations        String[]
  overthinkItems     String[]
  relationshipStatus String?
  onboardingStage    Int      @default(1) // Stage 1 to 5, 6 is complete
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model EpisodicMemory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      String
  emotion    String?
  importance Int      @default(5) // 1 to 10
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([timestamp])
}

model CompanionMessage {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String            // "user" or "assistant"
  content   String
  createdAt DateTime          @default(now())
  emotions  EmotionAnalysis[]

  @@index([userId])
  @@index([createdAt])
}

model EmotionAnalysis {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId        String?
  companionMessage CompanionMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  dominantEmotion  String            // e.g. "Anxious", "Calm", "Stressed", "Excited", "Fearful", "Confident", "Melancholic", "Motivated"
  intensity        Float             // 0.0 to 1.0 or 1 to 10
  confidence       Float             // 0.0 to 1.0 confidence score from Claude
  sentiment        String            // "positive", "negative", "neutral"
  avoidance        Boolean           @default(false)
  overthinking     Boolean           @default(false)
  createdAt        DateTime          @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([messageId])
}

model ReflectionReport {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  summary         String
  fears           String[] // Detected recurring fears
  loops           String[] // Detected emotional loops
  avoidanceTrend  String?  // Avoidance behavior insights
  confidenceTrend String?  // Confidence trends
  insights        String[]
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
